# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your-account-id-here
CLOUDFLARE_API_TOKEN=your-api-token-here

# JWT Configuration
JWT_SECRET=change-this-to-a-long-random-secret-key
# Generate password hash with: node -e "const bcrypt = require('bcryptjs'); bcrypt.hash('your-password', 10).then(console.log)"
PASSWORD_HASH=$2a$10$your-bcrypt-hashed-password-here

# Database Configuration (for local development)
DATABASE_URL=postgresql://emailuser:emailpass@postgres:5432/emaildb
REDIS_URL=redis://redis:6379

# Frontend Configuration
VITE_API_URL=http://localhost:8787
VITE_AUTH_URL=http://localhost:8788

# Email Configuration
EMAIL_FROM=noreply@yourdomain.com
EMAIL_DOMAIN=yourdomain.com

# Rate Limiting
RATE_LIMIT_ATTEMPTS=5
RATE_LIMIT_WINDOW=900000

# Session Configuration
SESSION_SECRET=another-long-random-secret-for-sessions
SESSION_MAX_AGE=86400000

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Security Headers
CSP_POLICY=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'
